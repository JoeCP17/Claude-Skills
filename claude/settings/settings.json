{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "msbaek-tdd@msbaek-claude-plugins": true
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  }
}
