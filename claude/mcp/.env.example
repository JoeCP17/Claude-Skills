# MCP 서버 환경변수 템플릿
# 실제 값은 절대 커밋하지 말 것 - .env 파일로 복사 후 사용

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Notion MCP
NOTION_TOKEN=your_notion_token_here

# Datadog MCP
DD_API_KEY=your_datadog_api_key_here
DD_APPLICATION_KEY=your_datadog_application_key_here

# AWS / MySQL MCP
AWS_REGION=ap-northeast-2
MYSQL_HOSTNAME=your_db_cluster_endpoint_here
MYSQL_SECRET_ARN=your_secret_arn_here
MYSQL_DATABASE=your_database_name_here
